# Kết nối PostgreSQL — sao chép file này thành .env rồi sửa cho khớp máy bạn.
# Định dạng: postgresql://<user>:<password>@<host>:<port>/<database>
# Database "krakenocean" sẽ tự được tạo nếu chưa có.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/krakenocean
PORT=8787

# Bí mật ký token đăng nhập — BẮT BUỘC đặt ở production (chuỗi ngẫu nhiên, dài).
# Nếu không đặt: chỉ chạy được ở dev với secret tạm (KHÔNG an toàn cho production).
SESSION_SECRET=
# Hạn dùng token (ms), mặc định 7 ngày.
# TOKEN_TTL_MS=604800000
# Origin frontend được phép gọi API (phân tách bằng dấu phẩy).
CORS_ORIGIN=http://localhost:5173
